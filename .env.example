SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
# Set True only after HTTPS/domain is configured
USE_HTTPS=False
ALLOWED_HOSTS=your-domain.com,YOUR_EC2_PUBLIC_IP
CSRF_TRUSTED_ORIGINS=http://YOUR_EC2_PUBLIC_IP,https://your-domain.com

# Separate DB from CarLottery (carlottery) — use digitallottery on same Postgres
DB_NAME=digitallottery
DB_USER=digitallottery
DB_PASSWORD=YOUR_DB_PASSWORD
DB_HOST=localhost
DB_PORT=5432

# Use Redis DB index 1 so CarLottery (often /0) is not shared
REDIS_URL=redis://127.0.0.1:6379/1

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEB_APP_URL=https://your-domain.com

JWT_SECRET_KEY=change-me-another-long-random-string
