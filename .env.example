# Django / app
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=your-domain.com,YOUR_EC2_PUBLIC_IP
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# Database (PostgreSQL on EC2)
DATABASE_URL=postgres://carlottery:YOUR_DB_PASSWORD@localhost:5432/carlottery

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Telegram — set real token only on the server / local .env (never commit)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEB_APP_URL=https://your-domain.com

# JWT for mini-app auth
JWT_SECRET_KEY=change-me-another-long-random-string

# Optional payment verification (Telebirr API)
# TELEBIRR_VERIFY_API_KEY=
# CBE_USE_FALLBACK_PROXY=true
